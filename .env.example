# Kopyala: cp .env.example .env  —  .env Git'e girmez (docker compose bu dosyayı okur)
# Bu dosya docker-compose.yml ile aynı değişken isimlerini taşır. backend/.env.example = konteyner içi referans.

# --- Frontend (Next build: docker compose build --no-cache frontend) ---
NEXT_PUBLIC_API_URL=http://82.25.112.199:4000/api
NEXT_PUBLIC_WS_URL=http://82.25.112.199:4000
# Yerel: http://localhost:4000/api ve http://localhost:4000
# HTTPS: https://alanadiniz.com/api ve https://alanadiniz.com

# --- PostgreSQL ---
POSTGRES_PASSWORD=crm_secret_password

# --- Backend / CORS ---
NODE_ENV=production
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://82.25.112.199:3000

# WAHA Plus: docker-compose imajı devlikeapro/waha-plus:latest (özel repo).
# İlk kurulumda sunucuda: docker login → docker compose pull waha
# WAHA (compose waha servisi; webhook çoğu kurulumda compose varsayılanı yeter)
WAHA_API_KEY=
WAHA_NO_API_KEY=true
# Panel (ör. http://SUNUCU_IP:3001) — internete açıksa mutlaka doldurun; Plus gerekli
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=
# false = giriş zorunlu (şifre boş olmamalı). Geliştirme: True + boş şifre
WAHA_DASHBOARD_NO_PASSWORD=false
# WAHA_WEBHOOK_URL=http://backend:4000/api/waha/webhook

# Redis
REDIS_PASSWORD=

# WAHA senkron limitleri (backend)
SYNC_CHAT_LIMIT=99999
SYNC_MESSAGE_LIMIT=99999
SYNC_TIMEOUT_MS=60000

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# İyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

WAHA_WEBHOOK_SECRET=
