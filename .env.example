# Kopyala: cp .env.example .env  —  .env Git'e girmez (docker compose otomatik okur)
# VPS IP: 82.25.112.199 — alan adı + HTTPS olunca aşağıdaki http://... satırlarını https:// ile güncelle.

# --- Frontend (Next.js build sırasında gömülür; değişince: docker compose build --no-cache frontend) ---
NEXT_PUBLIC_API_URL=http://82.25.112.199:4000/api
NEXT_PUBLIC_WS_URL=http://82.25.112.199:4000
# Yerel PC (docker olmadan): http://localhost:4000/api ve http://localhost:4000
# İleride tek domain + reverse proxy:
# NEXT_PUBLIC_API_URL=https://crm.ornek.com/api
# NEXT_PUBLIC_WS_URL=https://crm.ornek.com

# --- PostgreSQL (postgres servisi + backend DATABASE_URL aynı parola) ---
POSTGRES_PASSWORD=crm_secret_password

# --- Backend ---
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://82.25.112.199:3000
# CORS buna bakar; sonunda / olmadan. Alan adı: https://crm.ornek.com

# WAHA webhook: Docker içi ağda WAHA→backend için varsayılan yeterli.
# WAHA_WEBHOOK_URL=http://backend:4000/api/waha/webhook

# API anahtarı (boş = WAHA_NO_API_KEY=true; canlıda doldurup WAHA_NO_API_KEY=false yap)
WAHA_API_KEY=
WAHA_NO_API_KEY=true

# WAHA panel şifresi (canlıda dashboard kapatmak/şifre vermek iyi olur)
WAHA_DASHBOARD_PASSWORD=
WAHA_DASHBOARD_NO_PASSWORD=True

# Redis (şifresiz compose ile uyumlu)
REDIS_PASSWORD=

# Senkron (isteğe bağlı)
SYNC_CHAT_LIMIT=999
SYNC_MESSAGE_LIMIT=500
SYNC_TIMEOUT_MS=60000

# SMTP — Şifremi unuttum
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# İyzico (isteğe bağlı)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Webhook imzası (isteğe bağlı)
WAHA_WEBHOOK_SECRET=

NODE_ENV=production
