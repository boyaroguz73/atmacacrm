# === Yerel (PC) backend: npm run start:dev ===
# DATABASE_URL=postgresql://crm_user:crm_secret_password@localhost:5432/whatsapp_crm
# REDIS_HOST=localhost
# WAHA_API_URL=http://localhost:3001

# === Docker Compose içi (crm-backend konteyneri) — kök .env ile compose bu değerleri geçirir ===
# Aşağıdakiler docker-compose.yml ile aynı isimlerde olmalı; gerçek değerler kök dizindeki .env dosyasında.

NODE_ENV=production
PORT=4000

DATABASE_URL=postgresql://crm_user:crm_secret_password@postgres:5432/whatsapp_crm

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=your-super-secret-jwt-key-change-this

FRONTEND_URL=http://localhost:3000

WAHA_API_URL=http://waha:3000
WAHA_API_KEY=
WAHA_WEBHOOK_URL=http://backend:4000/api/waha/webhook
WAHA_WEBHOOK_SECRET=

SYNC_CHAT_LIMIT=99999
SYNC_MESSAGE_LIMIT=99999
SYNC_TIMEOUT_MS=60000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
