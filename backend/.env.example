# Database
DATABASE_URL=postgresql://crm_user:crm_secret_password@localhost:5432/whatsapp_crm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# WAHA
WAHA_API_URL=http://localhost:3001
WAHA_API_KEY=
WAHA_WEBHOOK_URL=http://localhost:4000/api/waha/webhook

# App
PORT=4000
FRONTEND_URL=http://localhost:3000

# Senkronizasyon Ayarları
# WAHA'dan kaç chat çekilecek (sync-all için)
SYNC_CHAT_LIMIT=999
# Her chat için kaç mesaj çekilecek
SYNC_MESSAGE_LIMIT=500
# WAHA API istek timeout süresi (ms)
SYNC_TIMEOUT_MS=60000

# SMTP (Şifremi Unuttum)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com
