generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  ACCOUNTANT
  AGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum QuotePaymentMode {
  FULL
  DEPOSIT_50
}

enum CashDirection {
  INCOME
  EXPENSE
}

enum LedgerKind {
  RECEIVABLE
  PAYABLE
}

enum AccInvoiceStatus {
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DiscountType {
  PERCENT
  AMOUNT
}

enum ProductFeedSource {
  MANUAL
  XML
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  OFFER_SENT
  WON
  LOST
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum SessionStatus {
  STARTING
  SCAN_QR
  WORKING
  STOPPED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  EXPIRED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Organization {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  logo            String?
  primaryColor    String   @default("#25D366")
  secondaryColor  String   @default("#1a2238")
  plan            PlanType @default(FREE)
  maxUsers        Int      @default(5)
  maxSessions     Int      @default(1)
  isActive        Boolean  @default(true)
  settings        Json?
  billingEmail    String?
  billingName     String?
  billingAddress  String?
  taxNumber       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users            User[]
  sessions         WhatsappSession[]
  contacts         Contact[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  supportTickets   SupportTicket[]
  templates        MessageTemplate[]
  autoReplyFlows   AutoReplyFlow[]
  auditLogs        AuditLog[]
  integrations     OrgIntegration[]

  @@map("organizations")
}

model Subscription {
  id                 String             @id @default(uuid())
  organizationId     String
  plan               PlanType
  status             SubscriptionStatus @default(TRIALING)
  priceMonthly       Float
  currency           String             @default("TRY")
  iyzicoSubRef       String?            @unique
  iyzicoCustomerRef  String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id              String   @id @default(uuid())
  organizationId  String
  subscriptionId  String?
  amount          Float
  currency        String   @default("TRY")
  status          String   @default("pending")
  iyzicoPaymentId String?
  description     String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("invoices")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String
  role           UserRole      @default(AGENT)
  avatar         String?
  isActive       Boolean       @default(true)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization      Organization?      @relation(fields: [organizationId], references: [id])
  assignments       Assignment[]
  sentMessages      Message[]          @relation("SentByUser")
  activities        Activity[]
  agentMetrics      AgentMetric[]
  tasks             Task[]
  internalNotes     InternalNote[]
  templates         MessageTemplate[]  @relation("TemplateCreator")
  autoReplyFlows    AutoReplyFlow[]    @relation("FlowCreator")
  auditLogs         AuditLog[]         @relation("AuditLogs")
  createdTickets    SupportTicket[]    @relation("TicketCreator")
  assignedTickets   SupportTicket[]    @relation("TicketAssignee")
  ticketMessages    TicketMessage[]    @relation("TicketMessages")
  passwordResets    PasswordReset[]
  createdQuotes          Quote[]             @relation("QuoteCreator")
  createdOrders          SalesOrder[]        @relation("OrderCreator")
  createdAccInvoices     AccountingInvoice[] @relation("AccInvoiceCreator")
  cashBookEntries        CashBookEntry[]
  ledgerEntries          LedgerEntry[]
  deliveryNotes          DeliveryNote[]

  @@index([organizationId])
  @@map("users")
}

model WhatsappSession {
  id             String        @id @default(uuid())
  name           String        @unique
  phone          String?
  status         SessionStatus @default(STOPPED)
  webhookUrl     String?
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization  Organization?  @relation(fields: [organizationId], references: [id])
  conversations Conversation[]
  messages      Message[]

  @@index([organizationId])
  @@map("whatsapp_sessions")
}

model Contact {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  surname         String?
  email           String?
  avatarUrl       String?
  tags            String[] @default([])
  notes           String?
  source          String?
  company         String?
  city            String?
  address         String?
  taxNumber       String?  // VKN (Vergi Kimlik Numarası)
  identityNumber  String?  // TC Kimlik Numarası
  billingAddress  String?  // Fatura adresi
  shippingAddress String?  // Teslimat adresi
  metadata        Json?
  organizationId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization?  @relation(fields: [organizationId], references: [id])
  conversations Conversation[]
  lead          Lead?
  tasks         Task[]
  quotes             Quote[]
  orders             SalesOrder[]
  accountingInvoices AccountingInvoice[]
  ledgerEntries      LedgerEntry[]

  @@index([phone])
  @@index([organizationId])
  @@map("contacts")
}

model Conversation {
  id              String   @id @default(uuid())
  contactId       String
  sessionId       String
  lastMessageAt   DateTime @default(now())
  lastMessageText String?
  unreadCount     Int      @default(0)
  isArchived      Boolean  @default(false)
  isClosed        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  session       WhatsappSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages      Message[]
  assignments   Assignment[]
  internalNotes InternalNote[]

  @@unique([contactId, sessionId])
  @@index([lastMessageAt(sort: Desc)])
  @@index([contactId])
  @@index([sessionId])
  @@map("conversations")
}

model Message {
  id            String           @id @default(uuid())
  conversationId String
  sessionId     String
  waMessageId   String?          @unique
  direction     MessageDirection
  body          String?
  mediaType     MediaType?
  mediaUrl      String?
  mediaMimeType String?
  status        MessageStatus    @default(PENDING)
  sentById      String?
  timestamp     DateTime         @default(now())
  reactions     Json?
  isEdited      Boolean          @default(false)
  editedAt      DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  session      WhatsappSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sentBy       User?           @relation("SentByUser", fields: [sentById], references: [id])

  @@index([conversationId, timestamp(sort: Desc)])
  @@index([waMessageId])
  @@index([sessionId])
  @@map("messages")
}

model Lead {
  id          String     @id @default(uuid())
  contactId   String     @unique
  status      LeadStatus @default(NEW)
  value       Float?
  source      String?
  notes       String?
  /// LOST durumunda kayıp nedeni (serbest metin)
  lossReason  String?
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  contact    Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([status])
  @@map("leads")
}

model Assignment {
  id              String   @id @default(uuid())
  conversationId  String
  userId          String
  assignedAt      DateTime @default(now())
  unassignedAt    DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@map("assignments")
}

model Activity {
  id          String   @id @default(uuid())
  leadId      String?
  userId      String
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([userId])
  @@map("activities")
}

model AgentMetric {
  id                 String   @id @default(uuid())
  userId             String
  date               DateTime @db.Date
  messagesHandled    Int      @default(0)
  conversationsCount Int      @default(0)
  avgResponseTime    Int?
  leadsConverted     Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("agent_metrics")
}

model Task {
  id          String     @id @default(uuid())
  userId      String
  contactId   String?
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  dueAt       DateTime
  trigger     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([dueAt])
  @@map("tasks")
}

model InternalNote {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("internal_notes")
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("system_settings")
}

model MessageTemplate {
  id             String   @id @default(uuid())
  title          String
  body           String
  category       String?
  shortcut       String?  @unique
  createdBy      String
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator      User          @relation("TemplateCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([category])
  @@index([organizationId])
  @@map("message_templates")
}

model AutoReplyFlow {
  id             String   @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean  @default(false)
  trigger        String
  conditions     Json?
  steps          Json
  createdBy      String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator      User          @relation("FlowCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("auto_reply_flows")
}

model SupportTicket {
  id              String         @id @default(uuid())
  organizationId  String
  createdById     String
  assignedToId    String?
  subject         String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  category        String?
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  messages     TicketMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("support_tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation("TicketMessages", fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  organizationId String?
  action         String
  entity         String
  entityId       String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  user         User?         @relation("AuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([entity, action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model OrgIntegration {
  id             String   @id @default(uuid())
  organizationId String
  integrationKey String
  isEnabled      Boolean  @default(false)
  config         Json?
  purchasedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, integrationKey])
  @@index([organizationId])
  @@map("org_integrations")
}

// ─── Product categories (CRM; ürün.category metni ile eşleştirilebilir) ───

model ProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_categories")
}

// ─── Products ───

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  description String?
  unit        String   @default("Adet")
  unitPrice   Float
  currency    String   @default("TRY")
  vatRate     Int      @default(20)
  stock       Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Elle mi yoksa Google Shopping XML akışından mı geldi
  productFeedSource ProductFeedSource @default(MANUAL)

  /// g:product_type ile doldurulur (ürün kategorisi); elle düzenlenebilir
  category                String?

  // Google Merchant / Shopping RSS alanları
  productUrl              String?
  imageUrl                String?
  googleCondition         String?
  googleAvailability      String?
  googleIdentifierExists  String?
  /// g:price (liste fiyatı)
  listPrice               Float?
  /// g:sale_price
  salePriceAmount         Float?
  /// g:sale_price_effective_date ham metin (örn. ISO aralığı)
  salePriceEffectiveRange String?
  brand                   String?
  googleProductCategory   String?
  googleProductType       String?
  googleCustomLabel0      String?
  gtin                    String?
  /// g:additional_image_link URL listesi (JSON dizi)
  additionalImages        Json?
  xmlSyncedAt             DateTime?

  quoteItems QuoteItem[]
  orderItems OrderItem[]

  @@index([sku])
  @@index([productFeedSource])
  @@index([category])
  @@map("products")
}

// ─── Quotes ───

model Quote {
  id            String       @id @default(uuid())
  quoteNumber   Int          @unique @default(autoincrement())
  contactId     String
  createdById   String
  status        QuoteStatus  @default(DRAFT)
  currency      String       @default("TRY")
  subtotal      Float        @default(0)
  discountType  DiscountType @default(PERCENT)
  discountValue Float        @default(0)
  discountTotal Float        @default(0)
  vatTotal      Float        @default(0)
  grandTotal    Float        @default(0)
  validUntil    DateTime?
  deliveryDate  DateTime?
  notes         String?
  /// Bu teklife özel ödeme koşulları (sistem ayarını ezer)
  termsOverride String?
  /// Bu teklife özel alt not (sistem ayarını ezer)
  footerNoteOverride String?
  pdfUrl        String?
  /// Kabul sonrası ödeme modeli
  paymentMode   QuotePaymentMode @default(FULL)
  /// Kısmi ödeme tutarı (TL)
  partialPaymentAmount Float?
  acceptedAt    DateTime?
  /// Versiyon numarası (her güncelleme öncesi artırılır)
  currentVersion Int @default(1)
  /// PDF başlığı: PROFORMA | QUOTE
  documentKind  String       @default("PROFORMA")
  /// Yönetim panelinde kayıt elle güncellendi (müşteri PDF’lerinde gösterilmez)
  panelEditedAt DateTime?
  /// Temsilci bilgisi
  agentInfo     String?
  /// Renk/Kumaş bilgisi
  colorFabricInfo String?
  /// Ölçü bilgisi
  measurementInfo String?
  /// Genel toplam manuel düzenleme (doluysa hesaplanan yerine kullanılır)
  grandTotalOverride Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User           @relation("QuoteCreator", fields: [createdById], references: [id])
  items     QuoteItem[]
  versions  QuoteVersion[]
  order     SalesOrder?
  invoice   AccountingInvoice?

  @@index([contactId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("quotes")
}

model QuoteVersion {
  id        String   @id @default(uuid())
  quoteId   String
  version   Int
  snapshot  Json
  pdfUrl    String?
  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_versions")
}

model QuoteItem {
  id            String        @id @default(uuid())
  quoteId       String
  productId     String?
  name          String
  description   String?
  quantity      Float         @default(1)
  unitPrice     Float
  vatRate       Int           @default(20)
  discountType  DiscountType? @default(PERCENT)
  discountValue Float?        @default(0)
  lineTotal     Float         @default(0)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@map("quote_items")
}

// ─── Orders ───

model SalesOrder {
  id                    String      @id @default(uuid())
  orderNumber           Int         @unique @default(autoincrement())
  quoteId               String?     @unique
  contactId             String
  createdById           String
  status                OrderStatus @default(PENDING)
  currency              String      @default("TRY")
  subtotal              Float       @default(0)
  vatTotal              Float       @default(0)
  grandTotal            Float       @default(0)
  shippingAddress       String?
  notes                 String?
  /// Planlanan teslim tarihi; teklifteki teslim tarihinden siparişe kopyalanabilir
  expectedDeliveryDate  DateTime?
  /// Tekliften dönüşüm sonrası sipariş onay formu (PDF)
  confirmationPdfUrl    String?
  /// %50 ön ödemede teslim öncesi kalan tahsilat hatırlatması oluşturuldu mu
  depositBalanceReminderSent Boolean @default(false)
  /// Yönetim panelinde kayıt elle güncellendi
  panelEditedAt         DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  quote     Quote?             @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  contact   Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User               @relation("OrderCreator", fields: [createdById], references: [id])
  items             OrderItem[]
  invoice           AccountingInvoice?
  cashBookEntries   CashBookEntry[]
  deliveryNotes     DeliveryNote[]

  @@index([contactId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("sales_orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String?
  name      String
  quantity  Float   @default(1)
  unitPrice Float
  vatRate   Int     @default(20)
  lineTotal Float   @default(0)

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

// ─── Accounting Invoices ───

model AccountingInvoice {
  id              String           @id @default(uuid())
  invoiceNumber   Int              @unique @default(autoincrement())
  orderId         String?          @unique
  quoteId         String?          @unique
  contactId       String
  createdById     String
  status          AccInvoiceStatus @default(PENDING)
  currency        String           @default("TRY")
  subtotal        Float            @default(0)
  vatTotal        Float            @default(0)
  grandTotal      Float            @default(0)
  dueDate         DateTime?
  paidAt          DateTime?
  pdfUrl          String?
  uploadedPdfUrl  String?
  notes           String?
  /// Yönetim panelinde kayıt elle güncellendi
  panelEditedAt   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  order     SalesOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  quote     Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User        @relation("AccInvoiceCreator", fields: [createdById], references: [id])
  cashBookEntries CashBookEntry[]

  @@index([contactId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("accounting_invoices")
}

// ─── Manuel muhasebe (PDF / elle kayıt) ───

model CashBookEntry {
  id          String        @id @default(uuid())
  userId      String
  amount      Float
  direction   CashDirection
  description String
  occurredAt  DateTime      @default(now())
  orderId     String?
  invoiceId   String?
  pdfUrl      String?
  createdAt   DateTime      @default(now())

  user    User                 @relation(fields: [userId], references: [id])
  order   SalesOrder?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoice AccountingInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([occurredAt(sort: Desc)])
  @@map("cash_book_entries")
}

model LedgerEntry {
  id          String     @id @default(uuid())
  userId      String
  contactId   String?
  kind        LedgerKind
  title       String
  amount      Float
  currency    String     @default("TRY")
  dueDate     DateTime?
  notes       String?
  pdfUrl      String?
  createdAt   DateTime   @default(now())

  user    User     @relation(fields: [userId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contactId])
  @@map("ledger_entries")
}

model DeliveryNote {
  id            String   @id @default(uuid())
  orderId       String
  userId        String
  noteNumber    Int      @unique @default(autoincrement())
  shippedAt     DateTime @default(now())
  pdfUrl        String?
  notes         String?
  /// Sipariş kalemlerinin anlık görüntüsü (JSON)
  itemsSnapshot Json?
  createdAt     DateTime @default(now())

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@map("delivery_notes")
}
